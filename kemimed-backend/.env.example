# App
APP_NAME=KemiMed
APP_VERSION=1.0.0
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=http://localhost:3000,https://kemimed.kemirix.com

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/kemimed
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (Railway Redis)
REDIS_URL=redis://default:password@host:6379

# AI — DeepSeek V4 Flash (PRIMARY TEXT AI)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# AI — Gemini (VOICE + IMAGES)
GEMINI_API_KEY=AIza-your-gemini-key
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_STT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# AI — OpenAI (IMAGE GEN + FALLBACK)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_WHISPER_MODEL=whisper-1

# File Storage — Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=kemimed-uploads
R2_PUBLIC_URL=https://uploads.kemimed.kemirix.com

# File Upload Limits
MAX_IMAGES_PER_USER=10
MAX_PDFS_PER_USER=10
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_PDF_TYPES=application/pdf
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/ogg,audio/mp4,audio/webm
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg,video/quicktime

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@kemirix.com
SMTP_PASSWORD=your-smtp-password

# PubMed API
PUBMED_API_KEY=your-pubmed-key
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
